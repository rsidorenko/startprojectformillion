# TelegramBotVPN backend environment template
#
# Copy this file to .env and fill in real staging/test values:
#   cp backend/.env.example backend/.env
#
# backend/.env is local-only and MUST NOT be committed.
# Do not paste secrets into chat, tickets, PRs, issues, commits, or logs.
#
# Scripts read environment variables from the process environment.
# They do not auto-load .env files. Load before running commands:
#   Git Bash:  set -a; source backend/.env; set +a
#   PowerShell: Get-Content backend/.env | ForEach-Object { $n,$v = $_ -split '=',2; [Environment]::SetEnvironmentVariable($n,$v,'Process') }
#   Or export each variable manually in your shell.

# ── Secrets (never log, never commit, never share) ──────────────

# Telegram Bot API token (use a staging/test bot, not production)
BOT_TOKEN=<secret:staging-telegram-bot-token>

# PostgreSQL connection string (use staging/test DB, never production)
DATABASE_URL=postgresql://user:password@localhost:5432/testdb

# HMAC secret for payment fulfillment ingress signature verification
PAYMENT_FULFILLMENT_WEBHOOK_SECRET=<secret:staging-hmac-secret>

# HMAC secret for signed checkout references
TELEGRAM_CHECKOUT_REFERENCE_SECRET=<secret:staging-checkout-reference-secret>

# Secret token for Telegram webhook ingress (fail-closed if missing)
TELEGRAM_WEBHOOK_SECRET_TOKEN=<secret:staging-webhook-secret-token>

# ── Storefront configuration ────────────────────────────────────

# Public checkout page URL (HTTPS required in strict mode)
TELEGRAM_STOREFRONT_CHECKOUT_URL=https://example.invalid/checkout

# Public renewal page URL (HTTPS required in strict mode)
TELEGRAM_STOREFRONT_RENEWAL_URL=https://example.invalid/renew

# Public support page URL or @handle for /support command
TELEGRAM_STOREFRONT_SUPPORT_URL=https://example.invalid/support
TELEGRAM_STOREFRONT_SUPPORT_HANDLE=@example_support

# Display name and price shown by /plans command
TELEGRAM_STOREFRONT_PLAN_NAME=Example MVP Plan
TELEGRAM_STOREFRONT_PLAN_PRICE=Example price

# ── Webhook configuration ───────────────────────────────────────

# Public HTTPS URL for the Telegram webhook endpoint
# Required when TELEGRAM_WEBHOOK_HTTP_ENABLE=1
TELEGRAM_WEBHOOK_PUBLIC_URL=https://example.invalid/telegram/webhook

# Enable webhook ASGI entrypoint (disabled by default)
# Set to 1 for webhook mode; leave unset for polling mode
TELEGRAM_WEBHOOK_HTTP_ENABLE=

# Allow insecure webhook without secret token (local/dev only, never production)
TELEGRAM_WEBHOOK_ALLOW_INSECURE_LOCAL=

# Comma-separated allowed Telegram update types (default: message)
TELEGRAM_WEBHOOK_ALLOWED_UPDATES=message

# ── Feature flags (all disabled by default — safe posture) ──────
# Set to 1 to enable for staging validation.

# Enable /status, /get_access, /resend_access commands
TELEGRAM_ACCESS_RESEND_ENABLE=

# Enable payment fulfillment HTTP ingress endpoint
PAYMENT_FULFILLMENT_HTTP_ENABLE=

# Enable issuance operator entrypoint
ISSUANCE_OPERATOR_ENABLE=

# Enable ADM-02 ensure-access remediation path
ADM02_ENSURE_ACCESS_ENABLE=

# ── Subscription lifecycle ──────────────────────────────────────

# Default subscription period in days (1–3660)
SUBSCRIPTION_DEFAULT_PERIOD_DAYS=30

# ── Checkout reference TTL ──────────────────────────────────────

# Max age in seconds for signed checkout references
# Recommended production range: 86400–604800
# Strict hard bounds: 600–2592000
# Default when unset: 604800 (7 days)
TELEGRAM_CHECKOUT_REFERENCE_MAX_AGE_SECONDS=604800

# Acknowledge using default TTL when not explicitly set (set to 1 in strict mode)
TELEGRAM_CHECKOUT_REFERENCE_DEFAULT_TTL_ACCEPTED=

# ── Access reconcile ────────────────────────────────────────────

# Operator acknowledgment that periodic reconcile is scheduled (set to 1)
ACCESS_RECONCILE_SCHEDULE_ACK=

# Max allowed interval in seconds between reconcile runs (300–86400)
ACCESS_RECONCILE_MAX_INTERVAL_SECONDS=86400

# ── Retention (use with caution) ────────────────────────────────

# Enable destructive retention delete path (DO NOT enable without dry-run first)
OPERATIONAL_RETENTION_DELETE_ENABLE=

# Audit log retention period in days
ADM02_AUDIT_RETENTION_DAYS=

# ── Storefront fallback acknowledgments ─────────────────────────

# Acknowledge missing plan name/price and use fallback (strict mode only)
TELEGRAM_STOREFRONT_ALLOW_PLAN_FALLBACK=

# Acknowledge missing support URL/handle and use fallback (strict mode only)
TELEGRAM_STOREFRONT_ALLOW_SUPPORT_FALLBACK=

# ── Internal admin (ADM-01 / ADM-02 — only needed for admin validation)

# Enable ADM-01 internal HTTP diagnostics endpoint
ADM01_INTERNAL_HTTP_ENABLE=

# ADM-01 bind host (default: 127.0.0.1)
ADM01_INTERNAL_HTTP_BIND_HOST=

# ADM-01 bind port
ADM01_INTERNAL_HTTP_BIND_PORT=

# ADM-01 principal allowlist (comma-separated)
ADM01_INTERNAL_HTTP_ALLOWLIST=

# ── Operational / infrastructure ─────────────────────────────────

# Application environment (development|staging|production); default: development
APP_ENV=

# Debug mode (leave empty in production)
DEBUG=

# Enable PostgreSQL-backed repositories (set to 1 for runtime with DB)
SLICE1_USE_POSTGRES_REPOS=

# Strict launch preflight flag (alternative to --strict CLI flag)
LAUNCH_PREFLIGHT_STRICT=
